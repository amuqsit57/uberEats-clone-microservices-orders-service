# Orders Service Environment Variables

# Port
PORT=5001

# Database (SEPARATE from Auth Service - different URL)
DATABASE_URL="postgresql://user:password@localhost:5433/orders_db"

# Auth Service URL (for inter-service communication)
AUTH_SERVICE_URL="http://localhost:5000"

# JWT Secret (same as auth service for verification)
JWT_SECRET="your_jwt_secret_key_here"

# Environment
NODE_ENV="development"
